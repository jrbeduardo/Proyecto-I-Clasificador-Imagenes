    </diagram>
    <diagram id="eiRZvOcDbK-BgHm_3czt" name="Page-2">
        <mxGraphModel dx="216" dy="766" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="DzAftfwfHLRddQg7FdsR-1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="1560" y="120" width="380" height="900" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-2" value="CNN: jerarquia espacial clara" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="170" width="340" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-3" value="En una CNN las primeras capas detectan bordes/texturas universales y las ultimas detectan partes de objeto especificas. Por eso es comun congelar las primeras y solo entrenar las ultimas: las features bajas ya sirven." style="text;html=1;align=left;fontSize=10;spacingLeft=8;spacingRight=8;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="215" width="340" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-4" value="ViT: atencion global desde la primera capa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="315" width="340" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-5" value="Cada bloque mira TODA la imagen via self-attention. No hay separacion clara entre features low-level y high-level por capa: todos los bloques aprenden representaciones globales utiles. Congelar capas tempranas pierde capacidad de adaptacion." style="text;html=1;align=left;fontSize=10;spacingLeft=8;spacingRight=8;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="360" width="340" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-6" value="Dataset suficientemente grande" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="470" width="340" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-7" value="Food-101 tiene 75 750 imgs de train. Con datasets grandes, full fine-tune supera a linear probing. Linear probing solo gana cuando hay POCAS imgs (cientos) o GPU muy limitada." style="text;html=1;align=left;fontSize=10;spacingLeft=8;spacingRight=8;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="515" width="340" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-8" value="Cambio de dominio (fine-grained)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="605" width="340" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-9" value="ImageNet tiene comida pero no a este nivel de detalle (ramen vs pho, donut vs beignet). Para fine-grained, dejar que el backbone se ajuste mejora la separacion entre clases parecidas." style="text;html=1;align=left;fontSize=10;spacingLeft=8;spacingRight=8;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="650" width="340" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="DzAftfwfHLRddQg7FdsR-11" value="Linear probing : dataset chico (cientos)&#xa;Last-N blocks  : dataset mediano + GPU limitada&#xa;Full fine-tune : dataset grande, dominio nuevo&#xa;                          (Food-101 cae aqui)" style="text;html=1;align=left;fontSize=10;fontFamily=Courier New;spacingLeft=8;spacingRight=8;whiteSpace=wrap;" vertex="1" parent="1">
                    <mxGeometry x="1580" y="775" width="340" height="100" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>